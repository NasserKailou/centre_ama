{% extends 'base.html.twig' %}
{% block title %}Reçu {{ facture.numero }} — CSI{% endblock %}
{% block page_title %}<i class="fas fa-receipt me-2 text-primary"></i>Reçu de Paiement{% endblock %}

{% block stylesheets %}
<style>
@media print {
    body { background: white; }
    .no-print { display: none !important; }
    .sidebar, .topbar, nav, .breadcrumb { display: none !important; }
    .main-content { margin-left: 0 !important; padding: 0 !important; }
    .card { box-shadow: none !important; border: none !important; }
    #recuPrintable { padding: 0 !important; }
}
</style>
{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4 no-print">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="{{ path('app_caisse_index') }}">Caisse</a></li>
            <li class="breadcrumb-item active">{{ facture.numero }}</li>
        </ol>
    </nav>
    <div class="d-flex gap-2">
        <button onclick="window.print()" class="btn btn-primary">
            <i class="fas fa-print me-1"></i>Imprimer
        </button>
        <a href="{{ path('app_caisse_new') }}" class="btn btn-success">
            <i class="fas fa-plus me-1"></i>Nouvelle Facture
        </a>
        <a href="{{ path('app_caisse_index') }}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Retour
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm" id="recuPrintable">
            <div class="card-body p-5">

                {# En-tête clinique #}
                <div class="text-center border-bottom pb-4 mb-4">
                    <div style="font-size:14px;font-weight:700;color:#1e40af;letter-spacing:1px;">
                        CENTRE DE SANTÉ INTÉGRÉ — CSI
                    </div>
                    <div style="font-size:11px;color:#64748b;margin-top:4px;">
                        Niamey, Quartier Couronne Nord<br>
                        Tél: +227 20 36 03 88 / Cel: 94 34 03 88
                    </div>
                </div>

                {# Titre reçu #}
                <div class="text-center mb-4">
                    <div style="font-size:20px;font-weight:800;color:#1e40af;letter-spacing:2px;">
                        REÇU N° {{ facture.numero }}
                    </div>
                    <div style="font-size:12px;color:#64748b;">
                        Niamey, le {{ facture.createdAt|date('d/m/Y') }}
                        — Statut : <strong>{{ facture.statutLibelle }}</strong>
                    </div>
                </div>

                {# Infos patient #}
                <div class="mb-4">
                    <table style="width:100%;font-size:13px;">
                        <tr>
                            <td style="padding:4px 0;color:#64748b;width:40%;">Patient :</td>
                            <td style="padding:4px 0;font-weight:700;">{{ facture.patient.nomComplet }}</td>
                        </tr>
                        <tr>
                            <td style="padding:4px 0;color:#64748b;">Téléphone :</td>
                            <td style="padding:4px 0;">{{ facture.patient.telephone }}</td>
                        </tr>
                        <tr>
                            <td style="padding:4px 0;color:#64748b;">Mode paiement :</td>
                            <td style="padding:4px 0;" class="text-capitalize">{{ facture.modePaiement|replace({'_': ' '}) }}</td>
                        </tr>
                        {% if facture.partenaire %}
                        <tr>
                            <td style="padding:4px 0;color:#64748b;">Assurance :</td>
                            <td style="padding:4px 0;">{{ facture.partenaire.nom }} ({{ facture.tauxAssurance }}%)</td>
                        </tr>
                        {% endif %}
                    </table>
                </div>

                {# Tableau des prestations #}
                <table style="width:100%;border-collapse:collapse;font-size:13px;margin-bottom:20px;">
                    <thead>
                        <tr style="background:#1e40af;color:white;">
                            <th style="padding:8px 12px;text-align:left;">Désignation</th>
                            <th style="padding:8px 12px;text-align:center;">Qté</th>
                            <th style="padding:8px 12px;text-align:right;">Prix U.</th>
                            <th style="padding:8px 12px;text-align:right;">Sous-total</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for ligne in facture.lignes %}
                        <tr style="border-bottom:1px solid #f1f5f9;">
                            <td style="padding:10px 12px;font-weight:600;">{{ ligne.designation }}</td>
                            <td style="padding:10px 12px;text-align:center;">{{ ligne.quantite }}</td>
                            <td style="padding:10px 12px;text-align:right;">{{ ligne.prixUnitaire|number_format(0, ',', ' ') }}</td>
                            <td style="padding:10px 12px;text-align:right;font-weight:700;">{{ ligne.sousTotal|number_format(0, ',', ' ') }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>

                {# Séparateur #}
                <div style="border-top:2px dashed #e2e8f0;margin:16px 0;"></div>

                {# Récapitulatif financier #}
                <table style="width:100%;font-size:13px;">
                    <tr>
                        <td style="padding:4px 0;color:#64748b;">Total actes médicaux :</td>
                        <td style="padding:4px 0;text-align:right;">{{ facture.montantActes|number_format(0, ',', ' ') }} FCFA</td>
                    </tr>
                    <tr>
                        <td style="padding:4px 0;color:#64748b;">Total pharmacie :</td>
                        <td style="padding:4px 0;text-align:right;">{{ facture.montantPharmacie|number_format(0, ',', ' ') }} FCFA</td>
                    </tr>
                    <tr>
                        <td style="padding:4px 0;font-weight:600;">Montant Total :</td>
                        <td style="padding:4px 0;text-align:right;font-weight:600;">{{ facture.montantTotal|number_format(0, ',', ' ') }} FCFA</td>
                    </tr>
                    {% if facture.partAssurance > 0 %}
                    <tr>
                        <td style="padding:4px 0;color:#0369a1;">Part Assurance ({{ facture.tauxAssurance }}%) :</td>
                        <td style="padding:4px 0;text-align:right;color:#0369a1;">- {{ facture.partAssurance|number_format(0, ',', ' ') }} FCFA</td>
                    </tr>
                    {% endif %}
                    <tr style="border-top:1px solid #e2e8f0;">
                        <td style="padding:8px 0;font-size:14px;font-weight:700;">NET À PAYER :</td>
                        <td style="padding:8px 0;text-align:right;font-size:16px;font-weight:800;color:#1e40af;">
                            {{ facture.partPatient|number_format(0, ',', ' ') }} FCFA
                        </td>
                    </tr>
                    {% if facture.montantRecu > 0 %}
                    <tr>
                        <td style="padding:4px 0;color:#059669;">Montant Reçu :</td>
                        <td style="padding:4px 0;text-align:right;color:#059669;font-weight:600;">{{ facture.montantRecu|number_format(0, ',', ' ') }} FCFA</td>
                    </tr>
                    <tr>
                        <td style="padding:4px 0;color:#64748b;">Monnaie Rendue :</td>
                        <td style="padding:4px 0;text-align:right;font-weight:600;">{{ facture.monnaieRendue|number_format(0, ',', ' ') }} FCFA</td>
                    </tr>
                    {% endif %}
                </table>

                {# Montant en lettres #}
                <div style="margin-top:16px;padding:12px;background:#f0f7ff;border-radius:8px;border-left:4px solid #1e40af;">
                    <strong style="font-size:12px;color:#1e40af;">
                        Arrêtez le présent reçu à la somme de :
                        <span style="font-size:13px;">{{ facture.partPatient|number_format(0, ',', ' ') }} Francs CFA</span>
                    </strong>
                </div>

                {# Signatures #}
                <div style="margin-top:32px;display:flex;justify-content:space-between;align-items:flex-end;">
                    <div style="text-align:center;">
                        <div style="font-size:12px;color:#64748b;margin-bottom:40px;">Patient(e)</div>
                        <div style="border-top:1px solid #94a3b8;width:120px;text-align:center;padding-top:4px;font-size:11px;color:#94a3b8;">Signature</div>
                    </div>
                    <div style="text-align:center;">
                        <div style="font-size:12px;color:#1e40af;font-weight:600;margin-bottom:8px;">
                            Meilleure santé !
                        </div>
                        <div style="font-size:11px;color:#64748b;">Caissier: {{ facture.caissier.nomComplet }}</div>
                        <div style="border-top:1px solid #94a3b8;width:120px;text-align:center;padding-top:4px;margin:8px auto 0;font-size:11px;color:#94a3b8;">Signature &amp; Cachet</div>
                    </div>
                </div>

                {# Pied de page #}
                <div style="margin-top:20px;text-align:center;font-size:11px;color:#94a3b8;border-top:1px dashed #e2e8f0;padding-top:12px;">
                    Ce reçu est valable comme justificatif de paiement — {{ facture.createdAt|date('d/m/Y à H:i') }}
                </div>

            </div>
        </div>
    </div>
</div>
{% endblock %}
