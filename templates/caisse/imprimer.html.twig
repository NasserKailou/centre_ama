<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Facture {{ facture.numero }} — CSI</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: Arial, sans-serif; font-size: 12px; color: #1e293b; padding: 20px; }
        .header { text-align: center; border-bottom: 2px solid #1e40af; padding-bottom: 12px; margin-bottom: 16px; }
        .header h1 { font-size: 18px; font-weight: 700; color: #1e40af; }
        .header p  { font-size: 11px; color: #64748b; }
        .badge-facture { display: inline-block; background: #dbeafe; color: #1d4ed8; font-size: 14px; font-weight: 700; padding: 4px 12px; border-radius: 6px; margin-bottom: 8px; }
        .two-col { display: flex; gap: 20px; margin-bottom: 16px; }
        .box { flex: 1; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 6px; padding: 10px; }
        .box label { font-size: 10px; color: #94a3b8; text-transform: uppercase; letter-spacing: .5px; display: block; margin-bottom: 2px; }
        .box p { font-size: 12px; font-weight: 600; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 12px; }
        thead th { background: #1e40af; color: #fff; padding: 6px 8px; font-size: 11px; text-align: left; }
        tbody td { padding: 5px 8px; border-bottom: 1px solid #e2e8f0; font-size: 11px; }
        tbody tr:last-child td { border-bottom: none; }
        .text-right { text-align: right; }
        .totaux { width: 280px; margin-left: auto; }
        .totaux td { padding: 4px 8px; }
        .totaux .grand-total { font-weight: 700; font-size: 14px; color: #1d4ed8; border-top: 2px solid #1e40af; }
        .badge-statut { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
        .statut-paye    { background: #dcfce7; color: #166534; }
        .statut-attente { background: #fef9c3; color: #854d0e; }
        .statut-partiel { background: #cffafe; color: #155e75; }
        .footer { margin-top: 20px; border-top: 1px solid #cbd5e1; padding-top: 10px; text-align: center; font-size: 10px; color: #94a3b8; }
        @media print {
            body { padding: 0; }
            button { display: none; }
        }
    </style>
</head>
<body>

{# En-tête clinique #}
<div class="header">
    <h1>Centre de Santé Intégré (CSI)</h1>
    <p>Facture / Reçu de Paiement</p>
</div>

<div style="text-align:center;margin-bottom:12px;">
    <span class="badge-facture">{{ facture.numero }}</span>
    &nbsp;&nbsp;
    <span class="badge-statut {{ facture.statut == 'paye' ? 'statut-paye' : (facture.statut == 'partiel' ? 'statut-partiel' : 'statut-attente') }}">
        {{ facture.statutLibelle }}
    </span>
</div>

{# Informations patient / facture #}
<div class="two-col">
    <div class="box">
        <label>Patient</label>
        <p>{{ facture.patient.nomComplet }}</p>
        {% if facture.patient.telephone %}<p style="font-weight:normal;color:#64748b;">{{ facture.patient.telephone }}</p>{% endif %}
    </div>
    <div class="box">
        <label>Date</label>
        <p>{{ facture.createdAt|date('d/m/Y H:i') }}</p>
        <label style="margin-top:6px;">Caissier</label>
        <p>{{ facture.caissier.nomComplet }}</p>
    </div>
    {% if facture.partenaire %}
    <div class="box">
        <label>Assurance</label>
        <p>{{ facture.partenaire.nom }}</p>
        <p style="font-weight:normal;color:#64748b;">Taux : {{ facture.tauxAssurance }}%</p>
    </div>
    {% endif %}
</div>

{# Lignes #}
<table>
    <thead>
        <tr>
            <th style="width:45%;">Désignation</th>
            <th>Type</th>
            <th class="text-right">Qté</th>
            <th class="text-right">Prix U.</th>
            <th class="text-right">Sous-total</th>
        </tr>
    </thead>
    <tbody>
    {% for ligne in facture.lignes %}
        <tr>
            <td>{{ ligne.designation }}</td>
            <td>{{ ligne.typeLigne == 'produit' ? 'Pharmacie' : 'Acte médical' }}</td>
            <td class="text-right">{{ ligne.quantite }}</td>
            <td class="text-right">{{ ligne.prixUnitaire|number_format(0, ',', ' ') }}</td>
            <td class="text-right">{{ ligne.sousTotal|number_format(0, ',', ' ') }}</td>
        </tr>
    {% endfor %}
    </tbody>
</table>

{# Totaux #}
<table class="totaux">
    <tr>
        <td>Actes médicaux :</td>
        <td class="text-right">{{ facture.montantActes|number_format(0, ',', ' ') }}</td>
    </tr>
    <tr>
        <td>Pharmacie :</td>
        <td class="text-right">{{ facture.montantPharmacie|number_format(0, ',', ' ') }}</td>
    </tr>
    <tr>
        <td><strong>Total brut :</strong></td>
        <td class="text-right"><strong>{{ facture.montantTotal|number_format(0, ',', ' ') }}</strong></td>
    </tr>
    {% if facture.partenaire %}
    <tr style="color:#0891b2;">
        <td>Part assurance ({{ facture.tauxAssurance }}%) :</td>
        <td class="text-right">- {{ facture.partAssurance|number_format(0, ',', ' ') }}</td>
    </tr>
    {% endif %}
    <tr class="grand-total">
        <td>PART PATIENT :</td>
        <td class="text-right">{{ facture.partPatient|number_format(0, ',', ' ') }} FCFA</td>
    </tr>
    {% if facture.montantRecu > 0 %}
    <tr style="color:#16a34a;">
        <td>Montant reçu :</td>
        <td class="text-right">{{ facture.montantRecu|number_format(0, ',', ' ') }}</td>
    </tr>
    <tr>
        <td>Monnaie rendue :</td>
        <td class="text-right">{{ facture.monnaieRendue|number_format(0, ',', ' ') }}</td>
    </tr>
    {% endif %}
</table>

{% if facture.notes %}
<p style="margin-top:12px;font-size:11px;color:#64748b;"><strong>Notes :</strong> {{ facture.notes }}</p>
{% endif %}

<div class="footer">
    <p>Document généré le {{ "now"|date("d/m/Y H:i") }} — Centre de Santé Intégré (CSI)</p>
    <p>Merci de votre confiance. Conservez ce document comme justificatif de paiement.</p>
</div>

<div style="margin-top:12px;text-align:center;" class="no-print">
    <button onclick="window.print()" style="background:#1e40af;color:white;border:none;padding:8px 20px;border-radius:6px;cursor:pointer;font-size:13px;">
        🖨 Imprimer
    </button>
    &nbsp;
    <button onclick="window.close()" style="background:#64748b;color:white;border:none;padding:8px 20px;border-radius:6px;cursor:pointer;font-size:13px;">
        ✕ Fermer
    </button>
</div>

</body>
</html>
