{% extends 'base.html.twig' %}
{% block title %}Situation Journalière - CSI{% endblock %}
{% block page_title %}<i class="fas fa-file-invoice-dollar me-2 text-primary"></i>Situation Journalière{% endblock %}

{% block stylesheets %}
<style>
@media print {
    .no-print { display: none !important; }
    .sidebar, .topbar { display: none !important; }
    .main-content { margin-left: 0 !important; padding: 0 !important; }
}
</style>
{% endblock %}

{% block content %}

{# ── Barre de filtre + bouton impression ─────────────────────────── #}
<div class="d-flex justify-content-between align-items-center mb-4 no-print">
    <form method="get" class="d-flex gap-2 align-items-center">
        <label class="fw-semibold me-1">Date :</label>
        <input type="date" name="date" value="{{ date|date('Y-m-d') }}" class="form-control" style="width:180px;">
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-search me-1"></i>Afficher
        </button>
    </form>
    <div class="d-flex gap-2">
        <a href="{{ path('app_caisse_index') }}" class="btn btn-outline-secondary no-print">
            <i class="fas fa-arrow-left me-1"></i>Retour caisse
        </a>
        <button onclick="window.print()" class="btn btn-outline-primary no-print">
            <i class="fas fa-print me-1"></i>Imprimer
        </button>
    </div>
</div>

{# ── Stats du jour ─────────────────────────────────────────────────── #}
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon stat-icon-blue"><i class="fas fa-file-invoice"></i></div>
            <div class="stat-content">
                <div class="stat-value">{{ stats.nb_factures ?? 0 }}</div>
                <div class="stat-label">Factures</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon stat-icon-green"><i class="fas fa-coins"></i></div>
            <div class="stat-content">
                <div class="stat-value">{{ (stats.total_encaisse ?? 0)|number_format(0, ',', ' ') }}</div>
                <div class="stat-label">Encaissé ({{ currency ?? 'FCFA' }})</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon stat-icon-cyan"><i class="fas fa-building"></i></div>
            <div class="stat-content">
                <div class="stat-value">{{ (stats.total_assurance ?? 0)|number_format(0, ',', ' ') }}</div>
                <div class="stat-label">Part Assurance ({{ currency ?? 'FCFA' }})</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon stat-icon-orange"><i class="fas fa-check-circle"></i></div>
            <div class="stat-content">
                <div class="stat-value">{{ stats.nb_payees ?? 0 }}</div>
                <div class="stat-label">Factures Payées</div>
            </div>
        </div>
    </div>
</div>

{# ── Tableau détail ─────────────────────────────────────────────── #}
<div class="card">
    <div class="card-header">
        <h5 class="card-header-title">
            <i class="fas fa-list me-2 text-primary"></i>
            Détail des Factures du {{ date|date('d/m/Y') }}
            {% if caissier %}
                <span class="text-muted fw-normal">— Caissier: {{ caissier.nomComplet }}</span>
            {% endif %}
        </h5>
    </div>

    <div class="card-body p-0">
        <table class="table table-modern mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>N° Facture</th>
                    <th>Patient</th>
                    <th>Prestations</th>
                    <th>Montant Total</th>
                    <th>Assurance</th>
                    <th>Part Patient</th>
                    <th>Statut</th>
                    <th class="no-print">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for i, facture in factures %}
                <tr>
                    <td><small class="text-muted">{{ i + 1 }}</small></td>
                    <td>
                        <span class="badge bg-primary-subtle text-primary">{{ facture.numero }}</span>
                    </td>
                    <td>
                        <div class="fw-semibold" style="font-size:13px;">{{ facture.patient.nomComplet }}</div>
                        <div class="text-muted" style="font-size:11px;">{{ facture.patient.telephone }}</div>
                    </td>
                    <td>
                        {% for ligne in facture.lignes %}
                            <div style="font-size:11px;color:#475569;">• {{ ligne.designation|slice(0,35) }}</div>
                        {% endfor %}
                    </td>
                    <td class="fw-bold">{{ facture.montantTotal|number_format(0, ',', ' ') }}</td>
                    <td class="text-info">{{ facture.partAssurance|number_format(0, ',', ' ') }}</td>
                    <td class="fw-bold text-primary">{{ facture.partPatient|number_format(0, ',', ' ') }}</td>
                    <td>
                        <span class="badge {{ facture.statut == 'paye' ? 'bg-success' : (facture.statut == 'partiel' ? 'bg-info' : 'bg-warning text-dark') }}">
                            {{ facture.statutLibelle }}
                        </span>
                    </td>
                    <td class="no-print">
                        <div class="btn-group btn-group-sm">
                            <a href="{{ path('app_caisse_recu', {'id': facture.id}) }}" class="btn btn-outline-primary" title="Reçu">
                                <i class="fas fa-receipt"></i>
                            </a>
                            <a href="{{ path('app_caisse_imprimer', {'id': facture.id}) }}" class="btn btn-outline-dark" target="_blank" title="Imprimer">
                                <i class="fas fa-print"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="9" class="text-center py-5 text-muted">
                        <i class="fas fa-calendar-times fa-2x mb-2 d-block opacity-25"></i>
                        Aucune facture ce jour
                    </td>
                </tr>
            {% endfor %}
            </tbody>

            {% if factures|length > 0 %}
            <tfoot style="background:#f0f7ff;font-weight:700;">
                <tr>
                    <td colspan="4" class="text-end">TOTAUX :</td>
                    <td>{{ (stats.total_encaisse ?? 0)|number_format(0, ',', ' ') }}</td>
                    <td class="text-info">{{ (stats.total_assurance ?? 0)|number_format(0, ',', ' ') }}</td>
                    <td class="text-primary">{{ (stats.total_patient ?? 0)|number_format(0, ',', ' ') }}</td>
                    <td colspan="2"></td>
                </tr>
            </tfoot>
            {% endif %}
        </table>
    </div>
</div>
{% endblock %}
