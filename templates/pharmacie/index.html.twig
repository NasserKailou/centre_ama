{% extends 'base.html.twig' %}
{% block title %}Pharmacie - CSI{% endblock %}
{% block page_title %}<i class="fas fa-pills me-2 text-primary"></i>Pharmacie - Stock Médicaments{% endblock %}
{% block content %}
<div class="row g-3 mb-4">
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon stat-icon-green"><i class="fas fa-pills"></i></div><div class="stat-content"><div class="stat-value">{{ stats.total }}</div><div class="stat-label">Produits Actifs</div></div></div></div>
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon {{ stats.ruptures > 0 ? 'stat-icon-red' : 'stat-icon-green' }}"><i class="fas fa-ban"></i></div><div class="stat-content"><div class="stat-value">{{ stats.ruptures }}</div><div class="stat-label">Ruptures de Stock</div></div></div></div>
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon {{ stats.alertes > 0 ? 'stat-icon-orange' : 'stat-icon-green' }}"><i class="fas fa-exclamation-triangle"></i></div><div class="stat-content"><div class="stat-value">{{ stats.alertes }}</div><div class="stat-label">En Alerte Stock</div></div></div></div>
</div>
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="search" value="{{ search }}" class="form-control form-control-sm" style="width:200px;" placeholder="Nom, DCI…">
            <select name="statut" class="form-select form-select-sm" style="width:140px;">
                <option value="">Tous stocks</option>
                <option value="disponible" {{ statut_filter == 'disponible' ? 'selected' : '' }}>Disponible</option>
                <option value="alerte" {{ statut_filter == 'alerte' ? 'selected' : '' }}>En alerte</option>
                <option value="rupture" {{ statut_filter == 'rupture' ? 'selected' : '' }}>Rupture</option>
            </select>
            <button type="submit" class="btn btn-primary btn-sm">Filtrer</button>
        </form>
        {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_pharmacie_new') }}" class="btn btn-success btn-sm"><i class="fas fa-plus me-1"></i>Nouveau Produit</a>
        {% endif %}
    </div>
    <div class="card-body p-0">
        <table class="table table-modern mb-0">
            <thead><tr><th>Produit</th><th>DCI</th><th>Forme/Dosage</th><th>Prix (FCFA)</th><th>Stock Actuel</th><th>Stock Min.</th><th>Statut</th><th>Actions</th></tr></thead>
            <tbody>
                {% for p in pagination %}
                <tr>
                    <td><div class="fw-semibold">{{ p.nom }}</div>{% if p.categorie %}<small class="text-muted">{{ p.categorie }}</small>{% endif %}</td>
                    <td><small class="text-muted">{{ p.dci ?? '—' }}</small></td>
                    <td><small>{{ p.dosage ?? '' }} {{ p.forme ?? '' }}</small></td>
                    <td class="fw-bold">{{ p.prix|number_format(0, ',', ' ') }}</td>
                    <td>
                        <span class="fw-bold {{ p.statutStock == 'rupture' ? 'text-danger' : (p.statutStock == 'alerte' ? 'text-warning' : 'text-success') }}">
                            {{ p.stockActuel }} {{ p.unite ?? '' }}
                        </span>
                    </td>
                    <td><small class="text-muted">{{ p.stockMinimum }}</small></td>
                    <td>
                        <span class="badge {{ p.statutStock == 'rupture' ? 'bg-danger' : (p.statutStock == 'alerte' ? 'bg-warning text-dark' : 'bg-success') }}">
                            {{ p.statutStock == 'rupture' ? 'RUPTURE' : (p.statutStock == 'alerte' ? 'ALERTE' : 'OK') }}
                        </span>
                    </td>
                    <td>
                        <div class="btn-group btn-group-sm">
                            <a href="{{ path('app_pharmacie_show', {'id': p.id}) }}" class="btn btn-outline-primary"><i class="fas fa-eye"></i></a>
                            {% if is_granted('ROLE_ADMIN') %}
                            <button class="btn btn-outline-success" onclick="reappro({{ p.id }}, '{{ p.nom|e('js') }}')" title="Réapprovisionner"><i class="fas fa-plus"></i></button>
                            {% endif %}
                            {% if is_granted('ROLE_CAISSIER') and p.statutStock != 'rupture' %}
                            <button class="btn btn-outline-warning" onclick="signalerRupture({{ p.id }}, '{{ p.nom|e('js') }}')" title="Signaler rupture"><i class="fas fa-exclamation"></i></button>
                            {% endif %}
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="8" class="text-center py-5 text-muted">Aucun produit trouvé</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% if pagination.pageCount > 1 %}<div class="card-footer bg-transparent">{{ knp_pagination_render(pagination) }}</div>{% endif %}
</div>

<!-- Modals -->
<div class="modal fade" id="reapproModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
    <div class="modal-header"><h5 class="modal-title"><i class="fas fa-boxes me-2"></i>Réapprovisionnement</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
        <p>Produit: <strong id="reapproNom"></strong></p>
        <div class="mb-3"><label class="form-label">Quantité à ajouter</label><input type="number" id="reapproQte" class="form-control" min="1" value="10"></div>
        <div><label class="form-label">Motif</label><input type="text" id="reapproMotif" class="form-control" value="Réapprovisionnement"></div>
    </div>
    <div class="modal-footer"><button type="button" class="btn btn-success" onclick="saveReappro()"><i class="fas fa-check me-1"></i>Valider</button></div>
</div></div></div>

<div class="modal fade" id="ruptureModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
    <div class="modal-header"><h5 class="modal-title text-danger"><i class="fas fa-exclamation-triangle me-2"></i>Signaler Rupture</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
        <p>Signaler la rupture pour: <strong id="ruptureNom"></strong></p>
        <div><label class="form-label">Motif</label><input type="text" id="ruptureMotif" class="form-control" value="Rupture signalée par le caissier"></div>
    </div>
    <div class="modal-footer"><button type="button" class="btn btn-warning" onclick="saveRupture()"><i class="fas fa-exclamation me-1"></i>Signaler</button></div>
</div></div></div>
{% endblock %}
{% block javascripts %}
<script>
let currentProduitId = null;
function reappro(id, nom) {
    currentProduitId = id;
    document.getElementById('reapproNom').textContent = nom;
    new bootstrap.Modal(document.getElementById('reapproModal')).show();
}
function saveReappro() {
    const formData = new FormData();
    formData.append('quantite', document.getElementById('reapproQte').value);
    formData.append('motif', document.getElementById('reapproMotif').value);
    axios.post('/pharmacie/' + currentProduitId + '/reapprovisionner', formData)
        .then(res => { if (res.data.success) location.reload(); })
        .catch(err => alert(err.response?.data?.error || 'Erreur'));
}
function signalerRupture(id, nom) {
    currentProduitId = id;
    document.getElementById('ruptureNom').textContent = nom;
    new bootstrap.Modal(document.getElementById('ruptureModal')).show();
}
function saveRupture() {
    const formData = new FormData();
    formData.append('motif', document.getElementById('ruptureMotif').value);
    axios.post('/pharmacie/' + currentProduitId + '/signaler-rupture', formData)
        .then(res => { if (res.data.success) { alert(res.data.message); location.reload(); } });
}
</script>
{% endblock %}
