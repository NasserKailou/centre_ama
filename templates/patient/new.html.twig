{% extends 'base.html.twig' %}
{% block title %}Nouveau Patient - CSI{% endblock %}
{% block page_title %}<i class="fas fa-user-plus me-2 text-primary"></i>Nouveau Patient{% endblock %}

{% block content %}
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ path('app_patient_index') }}">Patients</a></li>
        <li class="breadcrumb-item active">Nouveau Patient</li>
    </ol>
</nav>

<form method="post" action="{{ path('app_patient_new') }}">
    <div class="row g-4">
        <!-- Identité -->
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-header-title"><i class="fas fa-id-card text-primary me-2"></i>Identité du Patient</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Nom <span class="text-danger">*</span></label>
                            <input type="text" name="nom" class="form-control" placeholder="NOM DE FAMILLE" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Prénom <span class="text-danger">*</span></label>
                            <input type="text" name="prenom" class="form-control" placeholder="Prénom(s)" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Téléphone Principal <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-phone"></i></span>
                                <input type="tel" name="telephone" class="form-control" placeholder="Ex: 96000000" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Téléphone Secondaire</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-phone-alt"></i></span>
                                <input type="tel" name="telephone2" class="form-control" placeholder="Optionnel">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Date de Naissance</label>
                            <input type="date" name="date_naissance" class="form-control">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Sexe</label>
                            <select name="sexe" class="form-select">
                                <option value="">— Choisir —</option>
                                <option value="M">Masculin</option>
                                <option value="F">Féminin</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Groupe Sanguin</label>
                            <select name="groupe_sanguin" class="form-select">
                                <option value="">— Inconnu —</option>
                                {% for gs in ['A+', 'A-', 'B+', 'B-', 'AB+', 'AB-', 'O+', 'O-'] %}
                                <option value="{{ gs }}">{{ gs }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Profession</label>
                            <input type="text" name="profession" class="form-control" placeholder="Profession">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Adresse</label>
                            <input type="text" name="adresse" class="form-control" placeholder="Quartier, ville">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Antécédents Médicaux -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-header-title"><i class="fas fa-history text-warning me-2"></i>Antécédents Médicaux</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold text-danger">Allergies Connues</label>
                            <textarea name="allergies" class="form-control" rows="2" 
                                      placeholder="Médicaments, aliments ou substances auxquels le patient est allergique…"></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Antécédents Médicaux</label>
                            <textarea name="antecedents_medicaux" class="form-control" rows="3"
                                      placeholder="Diabète, hypertension, asthme…"></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Antécédents Chirurgicaux</label>
                            <textarea name="antecedents_chirurgicaux" class="form-control" rows="3"
                                      placeholder="Opérations antérieures…"></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Antécédents Familiaux</label>
                            <textarea name="antecedents_familiaux" class="form-control" rows="3"
                                      placeholder="Maladies héréditaires…"></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-header-title"><i class="fas fa-phone-volume text-danger me-2"></i>Contact d'Urgence</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nom Complet</label>
                        <input type="text" name="contact_urgence" class="form-control" placeholder="Prénom Nom">
                    </div>
                    <div>
                        <label class="form-label fw-semibold">Téléphone</label>
                        <input type="tel" name="telephone_urgence" class="form-control" placeholder="Numéro de téléphone">
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="fas fa-save me-2"></i>Enregistrer le Patient
                        </button>
                        <a href="{{ path('app_patient_index') }}" class="btn btn-outline-secondary">
                            <i class="fas fa-times me-2"></i>Annuler
                        </a>
                    </div>
                    <div class="mt-3 p-3 bg-light rounded" style="font-size:12px;color:#64748b;">
                        <i class="fas fa-info-circle me-1 text-primary"></i>
                        Le numéro de dossier sera généré automatiquement au format <strong>CSI-AAAA-XXXXX</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
{% endblock %}
