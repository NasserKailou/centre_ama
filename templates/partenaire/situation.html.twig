{% extends 'base.html.twig' %}
{% block title %}Situation {{ partenaire.nom }} - CSI{% endblock %}
{% block page_title %}<i class="fas fa-file-invoice-dollar me-2 text-primary"></i>Situation : {{ partenaire.nom }}{% endblock %}

{% block stylesheets %}
<style>
@media print {
    .no-print { display: none !important; }
    .sidebar, .topbar { display: none !important; }
    .main-content { margin-left: 0 !important; padding: 0 !important; }
}
</style>
{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4 no-print">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="{{ path('app_partenaire_index') }}">Partenaires</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_partenaire_show', {'id': partenaire.id}) }}">{{ partenaire.nom }}</a></li>
            <li class="breadcrumb-item active">Situation</li>
        </ol>
    </nav>
    <div class="d-flex gap-2">
        <button onclick="window.print()" class="btn btn-outline-primary btn-sm">
            <i class="fas fa-print me-1"></i>Imprimer
        </button>
        <a href="{{ path('app_partenaire_index') }}" class="btn btn-secondary btn-sm">
            <i class="fas fa-arrow-left me-1"></i>Retour
        </a>
    </div>
</div>

{# Filtre période #}
<div class="card mb-4 no-print">
    <div class="card-body">
        <form method="GET" class="d-flex gap-3 align-items-end flex-wrap">
            <div>
                <label class="form-label fw-semibold small">Du</label>
                <input type="date" name="date_debut" value="{{ date_debut }}" class="form-control">
            </div>
            <div>
                <label class="form-label fw-semibold small">Au</label>
                <input type="date" name="date_fin" value="{{ date_fin }}" class="form-control">
            </div>
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-search me-1"></i>Filtrer
            </button>
        </form>
    </div>
</div>

{# Infos partenaire + Stats #}
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body text-center">
                <div class="mb-3">
                    <i class="fas fa-building fa-3x text-primary opacity-75"></i>
                </div>
                <h5 class="fw-bold">{{ partenaire.nom }}</h5>
                <span class="badge bg-primary-subtle text-primary text-capitalize">{{ partenaire.type }}</span>
                <div class="mt-2 fw-bold text-success fs-5">{{ partenaire.tauxPriseEnCharge }}%</div>
                <div class="text-muted small">Taux de prise en charge</div>
            </div>
        </div>
    </div>
    <div class="col-md-9">
        <div class="row g-3">
            <div class="col-sm-3">
                <div class="stat-card">
                    <div class="stat-icon stat-icon-blue"><i class="fas fa-users"></i></div>
                    <div class="stat-content">
                        <div class="stat-value">{{ stats.nbPatients ?? 0 }}</div>
                        <div class="stat-label">Patients</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-3">
                <div class="stat-card">
                    <div class="stat-icon stat-icon-green"><i class="fas fa-file-invoice"></i></div>
                    <div class="stat-content">
                        <div class="stat-value">{{ stats.nbFactures ?? 0 }}</div>
                        <div class="stat-label">Factures</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-3">
                <div class="stat-card">
                    <div class="stat-icon stat-icon-orange"><i class="fas fa-coins"></i></div>
                    <div class="stat-content">
                        <div class="stat-value" style="font-size:1.1rem;">{{ (stats.montantBrut ?? 0)|number_format(0, ',', ' ') }}</div>
                        <div class="stat-label">Montant brut ({{ currency }})</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-3">
                <div class="stat-card">
                    <div class="stat-icon stat-icon-cyan"><i class="fas fa-shield-alt"></i></div>
                    <div class="stat-content">
                        <div class="stat-value" style="font-size:1.1rem;">{{ (stats.partAssurance ?? 0)|number_format(0, ',', ' ') }}</div>
                        <div class="stat-label">Part assurance ({{ currency }})</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="mt-3 p-3 bg-light rounded">
            <div class="row text-center">
                <div class="col">
                    <div class="text-muted small">Période analysée</div>
                    <div class="fw-bold">{{ date_debut|date('d/m/Y') }} → {{ date_fin|date('d/m/Y') }}</div>
                </div>
                <div class="col">
                    <div class="text-muted small">Reste à charge patients</div>
                    <div class="fw-bold text-primary">{{ (stats.restePatient ?? 0)|number_format(0, ',', ' ') }} {{ currency }}</div>
                </div>
            </div>
        </div>
    </div>
</div>

{# Tableau détail factures #}
<div class="card">
    <div class="card-header">
        <h5 class="card-header-title">
            <i class="fas fa-list me-2 text-primary"></i>
            Détail des factures du {{ date_debut|date('d/m/Y') }} au {{ date_fin|date('d/m/Y') }}
        </h5>
    </div>
    <div class="card-body p-0">
        <table class="table table-modern mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>N° Facture</th>
                    <th>Patient</th>
                    <th class="text-end">Montant Total</th>
                    <th class="text-end">Part Assurance</th>
                    <th class="text-end">Part Patient</th>
                    <th>Date</th>
                    <th>Statut</th>
                </tr>
            </thead>
            <tbody>
            {% for i, facture in factures %}
                <tr>
                    <td><small class="text-muted">{{ i + 1 }}</small></td>
                    <td><span class="badge bg-primary-subtle text-primary">{{ facture.numero }}</span></td>
                    <td>
                        <div class="fw-semibold" style="font-size:13px;">{{ facture.patient.nomComplet }}</div>
                    </td>
                    <td class="text-end fw-semibold">{{ facture.montantTotal|number_format(0, ',', ' ') }}</td>
                    <td class="text-end text-info">{{ facture.partAssurance|number_format(0, ',', ' ') }}</td>
                    <td class="text-end fw-bold text-primary">{{ facture.partPatient|number_format(0, ',', ' ') }}</td>
                    <td><small class="text-muted">{{ facture.createdAt|date('d/m/Y') }}</small></td>
                    <td>
                        <span class="badge {{ facture.statut == 'paye' ? 'bg-success' : (facture.statut == 'partiel' ? 'bg-info' : 'bg-warning text-dark') }}">
                            {{ facture.statutLibelle }}
                        </span>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8" class="text-center py-5 text-muted">
                        <i class="fas fa-file-invoice fa-2x mb-2 d-block opacity-25"></i>
                        Aucune facture pour ce partenaire sur cette période
                    </td>
                </tr>
            {% endfor %}
            </tbody>
            {% if factures|length > 0 %}
            <tfoot style="background:#f0f7ff;font-weight:700;">
                <tr>
                    <td colspan="3" class="text-end">TOTAUX :</td>
                    <td class="text-end">{{ (stats.montantBrut ?? 0)|number_format(0, ',', ' ') }}</td>
                    <td class="text-end text-info">{{ (stats.partAssurance ?? 0)|number_format(0, ',', ' ') }}</td>
                    <td class="text-end text-primary">{{ (stats.restePatient ?? 0)|number_format(0, ',', ' ') }}</td>
                    <td colspan="2"></td>
                </tr>
            </tfoot>
            {% endif %}
        </table>
    </div>
</div>
{% endblock %}
