###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_this_to_a_random_32_chars_secret_key
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Format: "mysql://user:password@host:port/dbname?serverVersion=8.0"
DATABASE_URL="mysql://csi_user:csi_password@127.0.0.1:3306/csi_sante?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

# Paramètres de l'application
APP_NAME="CSI - Centre de Santé Intégré"
APP_VERSION="1.0.0"
TIMEZONE="Africa/Niamey"
CURRENCY="FCFA"

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###
